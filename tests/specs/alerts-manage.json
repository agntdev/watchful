[
  {
    "name": "Manage Alerts shows empty state",
    "steps": [
      {
        "send": { "callback": "alerts:manage" },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": {
              "text": "No alerts yet — tap Create Alert to set one up."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "Alert creation - select type",
    "steps": [
      {
        "send": { "callback": "alerts:manage" },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "alerts:create" },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": {
              "text": "What type of alert?"
            }
          }
        ]
      }
    ]
  },
  {
    "name": "Price alert needs coins in watchlist",
    "steps": [
      {
        "send": { "callback": "alerts:price_threshold" },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": {
              "text": "Add a coin to your watchlist first."
            }
          }
        ]
      }
    ]
  }
]
